# MariaDB Configuration
DB_HOST=mariadb
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=app_password
DB_NAME=scientific_articles

# MongoDB Configuration
MONGO_URI=mongodb://root:rootpassword@mongodb:27017/scientific_articles?authSource=admin
MONGO_DB=scientific_articles

# ArXiv API Configuration
ARXIV_SEARCH_QUERY=transformer neural network
ARXIV_MAX_RESULTS=5
ARXIV_TIMEOUT=30

# Application Configuration
LOG_LEVEL=INFO
MAX_CONTENT_LENGTH=5000
REQUEST_TIMEOUT=15

# Admin Interfaces
ADMINER_URL=http://localhost:8080
MONGO_EXPRESS_URL=http://localhost:8081